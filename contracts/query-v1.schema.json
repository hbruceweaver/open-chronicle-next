{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openchronicle.dev/contracts/query-v1.schema.json",
  "title": "Open Chronicle query and disclosure contracts v1",
  "oneOf": [
    {"$ref": "#/$defs/request"},
    {"$ref": "#/$defs/response"},
    {"$ref": "#/$defs/grant"}
  ],
  "$defs": {
    "version": {"type": "string", "pattern": "^1\\.[0-9]+$"},
    "id": {"type": "string", "minLength": 1, "maxLength": 160, "pattern": "^(?!.*\\.\\.)[A-Za-z0-9_.:-]+$"},
    "dateTime": {"type": "string", "format": "date-time"},
    "nullableDateTime": {"oneOf": [{"$ref": "#/$defs/dateTime"}, {"type": "null"}]},
    "utcRange": {
      "type": "object",
      "required": ["start", "end"],
      "properties": {"start": {"$ref": "#/$defs/dateTime"}, "end": {"$ref": "#/$defs/dateTime"}},
      "additionalProperties": false
    },
    "contentClass": {"enum": ["metadata", "ocr", "derived"]},
    "limits": {
      "type": "object",
      "required": ["max_page_items", "max_response_bytes", "max_cumulative_bytes"],
      "properties": {
        "max_page_items": {"type": "integer", "minimum": 1},
        "max_response_bytes": {"type": "integer", "minimum": 1},
        "max_cumulative_bytes": {"type": "integer", "minimum": 1}
      },
      "additionalProperties": false
    },
    "pageRequest": {
      "type": "object",
      "required": ["cursor", "limit"],
      "properties": {"cursor": {"type": ["string", "null"]}, "limit": {"type": "integer", "minimum": 1}},
      "additionalProperties": false
    },
    "filter": {
      "type": "object",
      "required": ["range", "application_bundle_id", "window_text", "authorized_domain", "evidence_states"],
      "properties": {
        "range": {"$ref": "#/$defs/utcRange"},
        "application_bundle_id": {"type": ["string", "null"]},
        "window_text": {"type": ["string", "null"]},
        "authorized_domain": {"type": ["string", "null"]},
        "evidence_states": {"type": "array", "items": {"enum": ["captured-new", "captured-unchanged", "protected", "paused", "unavailable", "capture-failed"]}}
      },
      "additionalProperties": false
    },
    "operationKind": {"enum": ["status", "schemas", "list-chunks", "read-chunk", "get-event", "get-artifact", "search-activity", "inspect-moment", "statistics", "compare-periods", "supporting-evidence", "build-context-packet", "list-derived"]},
    "operation": {
      "oneOf": [
        {"type": "object", "required": ["type"], "properties": {"type": {"enum": ["status", "schemas"]}}, "additionalProperties": false},
        {"$ref": "#/$defs/listChunksOperation"},
        {"$ref": "#/$defs/idOperationReadChunk"},
        {"$ref": "#/$defs/idOperationGetEvent"},
        {"$ref": "#/$defs/getArtifactOperation"},
        {"$ref": "#/$defs/searchOperation"},
        {"$ref": "#/$defs/momentOperation"},
        {"$ref": "#/$defs/statisticsOperation"},
        {"$ref": "#/$defs/compareOperation"},
        {"$ref": "#/$defs/supportingOperation"},
        {"$ref": "#/$defs/contextOperation"},
        {"$ref": "#/$defs/listDerivedOperation"}
      ]
    },
    "listChunksOperation": {"type": "object", "required": ["type", "data"], "properties": {"type": {"const": "list-chunks"}, "data": {"type": "object", "required": ["filter", "page"], "properties": {"filter": {"$ref": "#/$defs/filter"}, "page": {"$ref": "#/$defs/pageRequest"}}, "additionalProperties": false}}, "additionalProperties": false},
    "idOperationReadChunk": {"type": "object", "required": ["type", "data"], "properties": {"type": {"const": "read-chunk"}, "data": {"type": "object", "required": ["chunk_id"], "properties": {"chunk_id": {"$ref": "#/$defs/id"}}, "additionalProperties": false}}, "additionalProperties": false},
    "idOperationGetEvent": {"type": "object", "required": ["type", "data"], "properties": {"type": {"const": "get-event"}, "data": {"type": "object", "required": ["event_id"], "properties": {"event_id": {"$ref": "#/$defs/id"}}, "additionalProperties": false}}, "additionalProperties": false},
    "getArtifactOperation": {"type": "object", "required": ["type", "data"], "properties": {"type": {"const": "get-artifact"}, "data": {"type": "object", "required": ["artifact_id", "revision_id"], "properties": {"artifact_id": {"$ref": "#/$defs/id"}, "revision_id": {"oneOf": [{"$ref": "#/$defs/id"}, {"type": "null"}]}}, "additionalProperties": false}}, "additionalProperties": false},
    "searchOperation": {"type": "object", "required": ["type", "data"], "properties": {"type": {"const": "search-activity"}, "data": {"type": "object", "required": ["filter", "query", "include_ocr", "page"], "properties": {"filter": {"$ref": "#/$defs/filter"}, "query": {"type": "string"}, "include_ocr": {"type": "boolean"}, "page": {"$ref": "#/$defs/pageRequest"}}, "additionalProperties": false}}, "additionalProperties": false},
    "momentOperation": {"type": "object", "required": ["type", "data"], "properties": {"type": {"const": "inspect-moment"}, "data": {"type": "object", "required": ["at"], "properties": {"at": {"$ref": "#/$defs/dateTime"}}, "additionalProperties": false}}, "additionalProperties": false},
    "statisticsOperation": {"type": "object", "required": ["type", "data"], "properties": {"type": {"const": "statistics"}, "data": {"type": "object", "required": ["filter"], "properties": {"filter": {"$ref": "#/$defs/filter"}}, "additionalProperties": false}}, "additionalProperties": false},
    "compareOperation": {"type": "object", "required": ["type", "data"], "properties": {"type": {"const": "compare-periods"}, "data": {"type": "object", "required": ["first", "second"], "properties": {"first": {"$ref": "#/$defs/utcRange"}, "second": {"$ref": "#/$defs/utcRange"}}, "additionalProperties": false}}, "additionalProperties": false},
    "supportingOperation": {"type": "object", "required": ["type", "data"], "properties": {"type": {"const": "supporting-evidence"}, "data": {"type": "object", "required": ["chunk_id", "page"], "properties": {"chunk_id": {"$ref": "#/$defs/id"}, "page": {"$ref": "#/$defs/pageRequest"}}, "additionalProperties": false}}, "additionalProperties": false},
    "contextOperation": {"type": "object", "required": ["type", "data"], "properties": {"type": {"const": "build-context-packet"}, "data": {"type": "object", "required": ["filter", "include_ocr", "max_bytes"], "properties": {"filter": {"$ref": "#/$defs/filter"}, "include_ocr": {"type": "boolean"}, "max_bytes": {"type": "integer", "minimum": 1}}, "additionalProperties": false}}, "additionalProperties": false},
    "listDerivedOperation": {"type": "object", "required": ["type", "data"], "properties": {"type": {"const": "list-derived"}, "data": {"type": "object", "required": ["range", "page"], "properties": {"range": {"$ref": "#/$defs/utcRange"}, "page": {"$ref": "#/$defs/pageRequest"}}, "additionalProperties": false}}, "additionalProperties": false},
    "evidenceSeconds": {
      "type": "object",
      "required": ["captured", "protected", "paused", "unavailable", "error", "gap"],
      "properties": {
        "captured": {"type": "integer", "minimum": 0},
        "protected": {"type": "integer", "minimum": 0},
        "paused": {"type": "integer", "minimum": 0},
        "unavailable": {"type": "integer", "minimum": 0},
        "error": {"type": "integer", "minimum": 0},
        "gap": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    },
    "presenceSeconds": {"type": "object", "required": ["active", "idle", "unknown"], "properties": {"active": {"type": "integer", "minimum": 0}, "idle": {"type": "integer", "minimum": 0}, "unknown": {"type": "integer", "minimum": 0}}, "additionalProperties": false},
    "gap": {"type": "object", "required": ["start", "end", "kind", "supporting_event_ids"], "properties": {"start": {"$ref": "#/$defs/dateTime"}, "end": {"$ref": "#/$defs/dateTime"}, "kind": {"enum": ["protected", "paused", "unavailable", "error", "missing-observation"]}, "supporting_event_ids": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/id"}}}, "additionalProperties": false},
    "durationEstimate": {"type": "object", "required": ["dimension", "key", "label", "estimated_seconds", "supporting_event_ids"], "properties": {"dimension": {"enum": ["application", "window", "authorized-domain"]}, "key": {"type": "string", "minLength": 1}, "label": {"type": "string", "minLength": 1}, "estimated_seconds": {"type": "integer", "minimum": 0, "maximum": 300}, "supporting_event_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/id"}}}, "additionalProperties": false},
    "transition": {"type": "object", "required": ["at", "from_key", "to_key", "supporting_event_id"], "properties": {"at": {"$ref": "#/$defs/dateTime"}, "from_key": {"oneOf": [{"type": "string", "minLength": 1}, {"type": "null"}]}, "to_key": {"type": "string", "minLength": 1}, "supporting_event_id": {"$ref": "#/$defs/id"}}, "additionalProperties": false},
    "ocrExtract": {"type": "object", "required": ["text", "source_event_id", "untrusted_evidence"], "properties": {"text": {"type": "string", "minLength": 1}, "source_event_id": {"$ref": "#/$defs/id"}, "untrusted_evidence": {"const": true}}, "additionalProperties": false},
    "coverage": {"type": "object", "required": ["range", "evidence_seconds", "presence_seconds", "gaps"], "properties": {"range": {"$ref": "#/$defs/utcRange"}, "evidence_seconds": {"$ref": "#/$defs/evidenceSeconds"}, "presence_seconds": {"$ref": "#/$defs/presenceSeconds"}, "gaps": {"type": "array", "items": {"$ref": "#/$defs/gap"}}}, "additionalProperties": false},
    "imageMetadata": {"type": "object", "required": ["artifact_id", "state", "expires_at"], "properties": {"artifact_id": {"$ref": "#/$defs/id"}, "state": {"enum": ["retained", "delete-pending", "expired", "user-deleted", "missing", "write-failed"]}, "expires_at": {"$ref": "#/$defs/nullableDateTime"}}, "additionalProperties": false},
    "windowContext": {"type": "object", "required": ["application_bundle_id", "process_name", "window_title", "authorized_domain"], "properties": {"application_bundle_id": {"type": "string", "minLength": 1}, "process_name": {"type": "string", "minLength": 1}, "window_title": {"oneOf": [{"type": "string", "minLength": 1}, {"type": "null"}]}, "authorized_domain": {"oneOf": [{"$ref": "#/$defs/authorizedDomain"}, {"type": "null"}]}}, "additionalProperties": false},
    "authorizedDomain": {"type": "object", "required": ["adapter", "domain"], "properties": {"adapter": {"type": "string", "minLength": 1}, "domain": {"type": "string", "minLength": 1}}, "additionalProperties": false},
    "ocr": {"type": "object", "required": ["text", "change", "confidence", "untrusted_evidence"], "properties": {"text": {"type": "string"}, "change": {"enum": ["new", "changed", "unchanged"]}, "confidence": {"type": ["number", "null"], "minimum": 0, "maximum": 1}, "untrusted_evidence": {"const": true}}, "additionalProperties": false},
    "queryObservationContent": {
      "oneOf": [
        {"type": "object", "required": ["type", "data"], "properties": {"type": {"const": "captured"}, "data": {"type": "object", "required": ["context", "content_hash", "ocr", "image"], "properties": {"context": {"$ref": "#/$defs/windowContext"}, "content_hash": {"type": "string", "minLength": 1}, "ocr": {"oneOf": [{"$ref": "#/$defs/ocr"}, {"type": "null"}]}, "image": {"oneOf": [{"$ref": "#/$defs/imageMetadata"}, {"type": "null"}]}}, "additionalProperties": false}}, "additionalProperties": false},
        {"type": "object", "required": ["type", "data"], "properties": {"type": {"const": "unchanged"}, "data": {"type": "object", "required": ["context", "content_hash", "previous_event_id", "reused_ocr_event_id", "image"], "properties": {"context": {"$ref": "#/$defs/windowContext"}, "content_hash": {"type": "string", "minLength": 1}, "previous_event_id": {"$ref": "#/$defs/id"}, "reused_ocr_event_id": {"oneOf": [{"$ref": "#/$defs/id"}, {"type": "null"}]}, "image": {"oneOf": [{"$ref": "#/$defs/imageMetadata"}, {"type": "null"}]}}, "additionalProperties": false}}, "additionalProperties": false},
        {"type": "object", "required": ["type", "data"], "properties": {"type": {"const": "protected"}, "data": {"type": "object", "required": ["reason", "privacy_policy_version"], "properties": {"reason": {"enum": ["secure-input", "application-excluded", "title-excluded", "chronicle-self", "foreground-changed"]}, "privacy_policy_version": {"type": "string", "minLength": 1}}, "additionalProperties": false}}, "additionalProperties": false},
        {"type": "object", "required": ["type", "data"], "properties": {"type": {"const": "no-evidence"}, "data": {"type": "object", "required": ["reason"], "properties": {"reason": {"enum": ["user-paused", "study-expired", "permission-denied", "locked", "asleep", "no-exact-window", "ambiguous-window", "capture-api-failure"]}}, "additionalProperties": false}}, "additionalProperties": false}
      ]
    },
    "queryObservation": {"type": "object", "required": ["cadence_seconds", "attempt_status", "evidence_state", "presence_state", "idle_seconds", "ocr_state", "content"], "properties": {"cadence_seconds": {"enum": [30, 60]}, "attempt_status": {"enum": ["completed", "skipped", "failed"]}, "evidence_state": {"enum": ["captured-new", "captured-unchanged", "protected", "paused", "unavailable", "capture-failed"]}, "presence_state": {"enum": ["active", "idle", "locked", "asleep", "unknown"]}, "idle_seconds": {"type": ["integer", "null"], "minimum": 0}, "ocr_state": {"enum": ["complete", "empty", "partial", "failed", "not-run"]}, "content": {"$ref": "#/$defs/queryObservationContent"}}, "additionalProperties": false, "allOf": [
      {"if": {"properties": {"presence_state": {"const": "idle"}}}, "then": {"properties": {"idle_seconds": {"type": "integer", "minimum": 1}}}},
      {"if": {"properties": {"presence_state": {"not": {"const": "idle"}}}}, "then": {"properties": {"idle_seconds": {"type": "null"}}}},
      {"if": {"properties": {"evidence_state": {"const": "captured-new"}}}, "then": {"properties": {"attempt_status": {"const": "completed"}, "presence_state": {"enum": ["active", "idle", "unknown"]}, "content": {"properties": {"type": {"const": "captured"}}}}}},
      {"if": {"properties": {"evidence_state": {"const": "captured-unchanged"}}}, "then": {"properties": {"attempt_status": {"const": "completed"}, "presence_state": {"enum": ["active", "idle", "unknown"]}, "ocr_state": {"const": "not-run"}, "content": {"properties": {"type": {"const": "unchanged"}}}}}},
      {"if": {"properties": {"evidence_state": {"const": "protected"}}}, "then": {"properties": {"attempt_status": {"const": "skipped"}, "ocr_state": {"const": "not-run"}, "content": {"properties": {"type": {"const": "protected"}}}}}},
      {"if": {"properties": {"evidence_state": {"const": "paused"}}}, "then": {"properties": {"attempt_status": {"const": "skipped"}, "ocr_state": {"const": "not-run"}, "content": {"allOf": [{"properties": {"type": {"const": "no-evidence"}}}, {"properties": {"data": {"properties": {"reason": {"enum": ["user-paused", "study-expired"]}}}}}]}}}},
      {"if": {"properties": {"evidence_state": {"const": "unavailable"}}}, "then": {"properties": {"attempt_status": {"const": "skipped"}, "ocr_state": {"const": "not-run"}, "content": {"allOf": [{"properties": {"type": {"const": "no-evidence"}}}, {"properties": {"data": {"properties": {"reason": {"enum": ["permission-denied", "locked", "asleep", "no-exact-window", "ambiguous-window"]}}}}}]}}}},
      {"if": {"properties": {"evidence_state": {"const": "capture-failed"}}}, "then": {"properties": {"attempt_status": {"const": "failed"}, "ocr_state": {"const": "not-run"}, "content": {"allOf": [{"properties": {"type": {"const": "no-evidence"}}}, {"properties": {"data": {"properties": {"reason": {"const": "capture-api-failure"}}}}}]}}}}
    ]},
    "lifecycle": {"type": "object", "required": ["artifact_id", "action", "deletion_cause", "projected_state", "requested_at", "completed_at", "source_event_id"], "properties": {"artifact_id": {"$ref": "#/$defs/id"}, "action": {"enum": ["write-completed", "delete-requested", "delete-completed", "missing", "write-failed"]}, "deletion_cause": {"type": ["string", "null"], "enum": ["retention-expired", "user-requested", null]}, "projected_state": {"enum": ["retained", "delete-pending", "expired", "user-deleted", "missing", "write-failed"]}, "requested_at": {"$ref": "#/$defs/nullableDateTime"}, "completed_at": {"$ref": "#/$defs/nullableDateTime"}, "source_event_id": {"$ref": "#/$defs/id"}}, "additionalProperties": false, "oneOf": [
      {"properties": {"action": {"const": "write-completed"}, "deletion_cause": {"type": "null"}, "projected_state": {"const": "retained"}, "requested_at": {"type": "null"}, "completed_at": {"type": "string"}}},
      {"properties": {"action": {"const": "delete-requested"}, "deletion_cause": {"enum": ["retention-expired", "user-requested"]}, "projected_state": {"const": "delete-pending"}, "requested_at": {"type": "string"}, "completed_at": {"type": "null"}}},
      {"properties": {"action": {"const": "delete-completed"}, "deletion_cause": {"const": "retention-expired"}, "projected_state": {"const": "expired"}, "requested_at": {"type": "string"}, "completed_at": {"type": "string"}}},
      {"properties": {"action": {"const": "delete-completed"}, "deletion_cause": {"const": "user-requested"}, "projected_state": {"const": "user-deleted"}, "requested_at": {"type": "string"}, "completed_at": {"type": "string"}}},
      {"properties": {"action": {"const": "missing"}, "deletion_cause": {"type": "null"}, "projected_state": {"const": "missing"}, "requested_at": {"type": "null"}, "completed_at": {"type": "string"}}},
      {"properties": {"action": {"const": "write-failed"}, "deletion_cause": {"type": "null"}, "projected_state": {"const": "write-failed"}, "requested_at": {"type": "null"}, "completed_at": {"type": "string"}}}
    ]},
    "queryEventPayload": {"oneOf": [
      {"type": "object", "required": ["type", "data"], "properties": {"type": {"const": "observation-attempt"}, "data": {"$ref": "#/$defs/queryObservation"}}, "additionalProperties": false},
      {"type": "object", "required": ["type", "data"], "properties": {"type": {"const": "recording-gap"}, "data": {"type": "object", "required": ["start", "end", "reason"], "properties": {"start": {"$ref": "#/$defs/dateTime"}, "end": {"$ref": "#/$defs/dateTime"}, "reason": {"enum": ["sleep", "quit", "storage-outage", "permission-loss", "clock-correction"]}}, "additionalProperties": false}}, "additionalProperties": false},
      {"type": "object", "required": ["type", "data"], "properties": {"type": {"const": "screenshot-lifecycle"}, "data": {"$ref": "#/$defs/lifecycle"}}, "additionalProperties": false}
    ]},
    "queryEvent": {"type": "object", "required": ["event_id", "device_id", "scheduled_at", "observed_at", "recorded_at", "display_timezone", "source", "kind", "payload"], "properties": {"event_id": {"$ref": "#/$defs/id"}, "device_id": {"$ref": "#/$defs/id"}, "scheduled_at": {"$ref": "#/$defs/nullableDateTime"}, "observed_at": {"$ref": "#/$defs/dateTime"}, "recorded_at": {"$ref": "#/$defs/dateTime"}, "display_timezone": {"type": "string", "minLength": 1}, "source": {"type": "object", "required": ["adapter", "version"], "properties": {"adapter": {"type": "string", "minLength": 1}, "version": {"type": "string", "minLength": 1}}, "additionalProperties": false}, "kind": {"enum": ["observation-attempt", "recording-gap", "screenshot-lifecycle"]}, "payload": {"$ref": "#/$defs/queryEventPayload"}}, "additionalProperties": false, "allOf": [
      {"if": {"properties": {"kind": {"const": "observation-attempt"}}}, "then": {"properties": {"scheduled_at": {"type": "string"}, "payload": {"properties": {"type": {"const": "observation-attempt"}}}}}},
      {"if": {"properties": {"kind": {"const": "recording-gap"}}}, "then": {"properties": {"scheduled_at": {"type": "null"}, "payload": {"properties": {"type": {"const": "recording-gap"}}}}}},
      {"if": {"properties": {"kind": {"const": "screenshot-lifecycle"}}}, "then": {"properties": {"scheduled_at": {"type": "null"}, "payload": {"properties": {"type": {"const": "screenshot-lifecycle"}}}}}}
    ]},
    "chunkSummary": {"type": "object", "required": ["chunk_id", "revision_id", "start", "end", "evidence_seconds", "presence_seconds", "late_input"], "properties": {"chunk_id": {"$ref": "#/$defs/id"}, "revision_id": {"$ref": "#/$defs/id"}, "start": {"$ref": "#/$defs/dateTime"}, "end": {"$ref": "#/$defs/dateTime"}, "evidence_seconds": {"$ref": "#/$defs/evidenceSeconds"}, "presence_seconds": {"$ref": "#/$defs/presenceSeconds"}, "late_input": {"type": "boolean"}}, "additionalProperties": false},
    "chunk": {"type": "object", "required": ["schema_version", "chunk_id", "revision_id", "prior_revision_id", "supersedes_revision_id", "window", "generated_at", "display_timezone", "aggregator_version", "input_digest", "store_generation", "finalization_cadence_seconds", "evidence_seconds", "presence_seconds", "duration_estimates", "transitions", "ocr_extracts", "gaps", "supporting_event_ids", "late_input"], "properties": {
      "schema_version": {"$ref": "#/$defs/version"}, "chunk_id": {"$ref": "#/$defs/id"}, "revision_id": {"$ref": "#/$defs/id"}, "prior_revision_id": {"oneOf": [{"$ref": "#/$defs/id"}, {"type": "null"}]}, "supersedes_revision_id": {"oneOf": [{"$ref": "#/$defs/id"}, {"type": "null"}]}, "window": {"$ref": "#/$defs/utcRange"}, "generated_at": {"$ref": "#/$defs/dateTime"}, "display_timezone": {"type": "string", "minLength": 1}, "aggregator_version": {"type": "string", "minLength": 1}, "input_digest": {"type": "string", "minLength": 1}, "store_generation": {"type": "integer", "minimum": 1}, "finalization_cadence_seconds": {"enum": [30, 60]}, "evidence_seconds": {"$ref": "#/$defs/evidenceSeconds"}, "presence_seconds": {"$ref": "#/$defs/presenceSeconds"}, "duration_estimates": {"type": "array", "items": {"$ref": "#/$defs/durationEstimate"}}, "transitions": {"type": "array", "items": {"$ref": "#/$defs/transition"}}, "ocr_extracts": {"type": "array", "items": {"$ref": "#/$defs/ocrExtract"}}, "gaps": {"type": "array", "items": {"$ref": "#/$defs/gap"}}, "supporting_event_ids": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/id"}}, "late_input": {"type": "boolean"}
    }, "additionalProperties": false},
    "author": {"type": "object", "required": ["kind", "display_name", "client_id", "model"], "properties": {"kind": {"enum": ["user", "consultant", "mcp-client", "model"]}, "display_name": {"type": ["string", "null"]}, "client_id": {"oneOf": [{"$ref": "#/$defs/id"}, {"type": "null"}]}, "model": {"type": ["string", "null"]}}, "additionalProperties": false},
    "evidenceReferences": {"type": "object", "required": ["event_ids", "chunk_ids"], "properties": {"event_ids": {"type": "array", "items": {"$ref": "#/$defs/id"}}, "chunk_ids": {"type": "array", "items": {"$ref": "#/$defs/id"}}}, "additionalProperties": false, "anyOf": [{"properties": {"event_ids": {"minItems": 1}}}, {"properties": {"chunk_ids": {"minItems": 1}}}]},
    "queryArtifact": {"type": "object", "required": ["artifact_id", "revision_id", "prior_revision_id", "artifact_type", "author", "created_at", "status", "payload", "evidence", "confidence", "store_generation"], "properties": {"artifact_id": {"$ref": "#/$defs/id"}, "revision_id": {"$ref": "#/$defs/id"}, "prior_revision_id": {"oneOf": [{"$ref": "#/$defs/id"}, {"type": "null"}]}, "artifact_type": {"enum": ["annotation", "tag", "hypothesis", "report"]}, "author": {"$ref": "#/$defs/author"}, "created_at": {"$ref": "#/$defs/dateTime"}, "status": {"enum": ["draft", "accepted", "rejected", "superseded"]}, "payload": {}, "evidence": {"$ref": "#/$defs/evidenceReferences"}, "confidence": {"type": ["number", "null"], "minimum": 0, "maximum": 1}, "store_generation": {"type": "integer", "minimum": 1}}, "additionalProperties": false},
    "schemaDescriptor": {"type": "object", "required": ["name", "major_version", "schema_id"], "properties": {"name": {"type": "string", "minLength": 1}, "major_version": {"type": "integer", "minimum": 1}, "schema_id": {"type": "string", "minLength": 1}}, "additionalProperties": false},
    "factualTotal": {"type": "object", "required": ["dimension", "key", "estimated_seconds", "supporting_chunk_ids"], "properties": {"dimension": {"enum": ["application", "window", "authorized-domain"]}, "key": {"type": "string", "minLength": 1}, "estimated_seconds": {"type": "integer", "minimum": 0}, "supporting_chunk_ids": {"type": "array", "items": {"$ref": "#/$defs/id"}}}, "additionalProperties": false},
    "queryResult": {"oneOf": [
      {"$ref": "#/$defs/statusResult"},
      {"$ref": "#/$defs/schemasResult"},
      {"$ref": "#/$defs/chunkListResult"},
      {"$ref": "#/$defs/chunkResult"},
      {"$ref": "#/$defs/eventResult"},
      {"$ref": "#/$defs/artifactResult"},
      {"$ref": "#/$defs/searchResult"},
      {"$ref": "#/$defs/momentResult"},
      {"$ref": "#/$defs/statisticsResult"},
      {"$ref": "#/$defs/comparisonResult"},
      {"$ref": "#/$defs/supportingResult"},
      {"$ref": "#/$defs/contextResult"},
      {"$ref": "#/$defs/derivedListResult"}
    ]},
